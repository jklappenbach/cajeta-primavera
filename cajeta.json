{
    // cajeta-primavera — best-of-breed enterprise framework for Cajeta.
    //
    // primavera is to Cajeta roughly what Spring is to Java: an opinionated layer
    // built ON the language's core DI substrate (@Component, @Inject, @Factory,
    // the compile-time graph) and neutral primitives (FiberLocal, reflection).
    // The LANGUAGE ships the substrate; primavera ships POLICY — request/session
    // scope, stereotypes, deployment profiles, web request/session models — so the
    // core stays small and other frameworks remain free to innovate.
    //
    // This is a LIBRARY project: no `entry-method`, compiles to a reusable
    // `.cja` archive. Consumers link only the parts they use (dead-code
    // elimination), which matters for the embedded/robotics targets Cajeta
    // is headed toward.

    "details": {
        "name":               "dev.cajeta.primavera",
        "version":            "0.1.0",
        "description":        "primavera — enterprise framework for Cajeta (components, web, request/session scope)",
        "license":            "Apache-2.0",
        "authors":            ["Julian Klappenbach"],
        "cajeta-lang-version": "1.0"
    },

    "settings": {
        // The compiler build this library is developed against (distinct from
        // `details.cajeta-lang-version`, which pins the language/stdlib API
        // surface). On this machine 0.9.2 is the locally built toolchain from
        // ~/code/cpp/cajeta (installed at /usr/lib/cajeta); its publish to
        // Olla (https://olla.cajeta.dev) is in flight, so `from` lets any
        // machine without the local build auto-fetch it once it lands.
        "toolchain": {
            "version": "0.9.2",
            "from":    "https://olla.cajeta.dev"
        },

        "capabilities": [],

        // Resolved from the local Olla repository (~/.olla; `cajeta install`
        // from the sibling checkouts) until the olla.cajeta.dev publishes land.
        "dependencies": {
            "dev.cajeta.logging": "0.5.*"
        },

        "dev-dependencies": {
            "dev.cajeta.unit": "0.1.*"
        },

        "repositories": [
            { "name": "olla", "url": "https://olla.cajeta.dev",
              "priority": 0 }
        ],

        "build": {
            "target": "host"
        }
    },

    "tasks": {

        "build": {
            "description": "Compile sources to a .cja library archive",
            "actions": [
                { "action": "build", "flavor": "debug", "id": "art" }
            ],
            "outputs": { "path": "${art.path}", "sha256": "${art.sha256}" }
        },

        "test": {
            "description": "Build + run primavera's unit tests (fails on any failure)",
            "actions": [
                { "action": "build", "flavor": "debug",
                  "entry-method": "dev.cajeta.primavera.selftest.SelfTest.run",
                  "id": "testbin" },
                { "action": "test", "input": "${testbin.path}" }
            ]
        },

        "release": {
            "description": "Optimized release build of the library (.cja)",
            "actions": [
                { "action": "build", "flavor": "release", "id": "art" }
            ],
            "outputs": { "path": "${art.path}", "sha256": "${art.sha256}" }
        },

        "clean": {
            "description": "Wipe build outputs",
            "actions": [ { "action": "clean" } ]
        }
    }
}
