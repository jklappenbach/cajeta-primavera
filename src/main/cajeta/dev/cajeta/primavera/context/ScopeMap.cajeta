package dev.cajeta.primavera.context;

import cajeta.collection.HashMap;

/**
 * A per-scope object store: a fully-qualified type name -> the single
 * instance bound for that type within one request (or session).
 *
 * The store OWNS its beans: `store` transfers the instance's title into the
 * backing map (title-tracking `#=` slot store), so when the ScopeMap drops at
 * scope end every bean's destructor runs and its memory is freed. The same
 * holds for eviction — a `HashMap.remove` whose result is discarded drops the
 * evicted value — which is what makes this store reusable as the per-session
 * bag under Phase 2's evicting SessionStore. (Requires toolchain >= 0.9.2:
 * earlier collections were non-owning and this store leaked; verified by
 * drop-tracking 2026-07-19, see plan/primavera-plan.md.)
 *
 * Keys are matched by CONTENT (`String.operator==` byte equality), not
 * identity — reflective type names are not guaranteed interned, so two equal
 * names may be distinct String objects. The map also owns a private copy of
 * each key (`substring` materializes one), so a stored binding never dangles
 * on a caller-owned key string that drops before the scope does.
 *
 * This is the runtime backing for request- and session-scoped @Component
 * beans (primavera's component lifecycle, documented in docs/Components.md).
 */
public class ScopeMap {
    HashMap<String, Object> instances;

    public ScopeMap() {
        this.instances = heap HashMap<String, Object>();
    }

    /** Whether an instance is already bound for `key`. */
    public boolean has(String key) {
        return this.instances.containsKey(key);
    }

    /** The instance bound for `key`, or null when none is bound. */
    public Object lookup(String key) {
        return this.instances.get(key);
    }

    /**
     * Bind `value` for `key`, taking ownership for the scope's lifetime.
     * Caller must check `has(key)` first for an idempotent get-or-create;
     * a re-store for the same key drops the displaced instance.
     */
    public void store(String key, #Object value) {
        // Own a copy of the key: the caller's string may drop before the
        // scope does, and the map must not hold a borrowed key past that.
        String owned #= key.substring(0, key.byteLength());
        this.instances.put(#owned, #value);
    }

    /** Number of scoped instances currently held. */
    public int32 count() {
        return (int32) this.instances.count();
    }
}
