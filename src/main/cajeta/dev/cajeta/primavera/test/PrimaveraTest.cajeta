package dev.cajeta.primavera.test;

import cajeta.concurrent.Channel;
import cajeta.concurrent.FiberContext;
import dev.cajeta.primavera.context.RequestScope;
import dev.cajeta.primavera.context.SessionScope;

/**
 * primavera's test facade (Phase 5): scope harnesses for exercising
 * request- and session-scoped code from tests. Deliberately free of any
 * cajeta-unit dependency — assertions are the test framework's job; this
 * class only stands scopes up, tears them down, and simulates the executor
 * behaviors a unit test cannot otherwise reach. Pair it with cajeta-unit's
 * `TestRunner`/`Assert`/mocks (and `TestContext` for `@Inject` overrides in
 * `--profile=test` builds).
 *
 * Mocking a scoped bean needs no special machinery: seed the scope with the
 * mock under the real key BEFORE the code under test runs — `materialize`'s
 * has() check then short-circuits the real factory:
 *
 * ```cajeta
 * PrimaveraTest.request(() -> {
 *     RequestScope.store(key, #(heap MockGateway()));   // seeded mock wins
 *     handler.handle(request);                          // resolves the mock
 * });
 * ```
 *
 * Call `reset()` between tests: the session store is process-wide state and
 * would otherwise bleed sessions and TTL config across tests.
 */
public class PrimaveraTest {
    // The in-flight handoff snapshot. Owned static rather than a
    // Channel<FiberContext> payload: transferring the snapshot itself
    // through Optional/channel slots crashes in the worker (ownership of
    // the snapshot is claimed twice); the channels below carry only
    // rendezvous signals. Overwritten (displaced) by the next handoff.
    static FiberContext captured;

    /** Run `body` inside a fresh request scope (drops with all its beans). */
    public static void request(() -> void body) {
        RequestScope.enter(body);
    }

    /**
     * Create a FRESH session under `id` (displacing — and dropping — any
     * prior session with that id) and run `body` attached to it. The
     * canonical per-test entry: the test always starts from a clean bag.
     */
    public static void freshSession(String id, () -> void body) {
        SessionScope.create(id);
        SessionScope.attach(id, body);
    }

    /**
     * Attach to an EXISTING session and run `body` — a later "request" of
     * the same client. Pair with `freshSession` to test cross-request
     * persistence; attaching to an id that was never created runs `body`
     * sessionless (isActive() false), which is itself a testable state.
     */
    public static void resumeSession(String id, () -> void body) {
        SessionScope.attach(id, body);
    }

    /**
     * Restore session state to a blank slate: drop every session (beans
     * free) and disable both TTLs. Call between tests — the store is
     * process-wide and never resets itself.
     */
    public static void reset() {
        SessionScope.invalidateAll();
        SessionScope.configure(0, 0);
    }

    /**
     * Simulate the completion-port executor's unstructured handoff — the
     * path a thread-per-request-only test can never exercise. `pre` runs
     * inside a fresh request scope on the originating fiber (seed beans,
     * do "pre-I/O" work); the harness then captures a `FiberContext`
     * snapshot and hands it to a WORKER fiber that was spawned with no
     * request bindings (as a pool worker is); the worker installs the
     * snapshot and runs `continuation` under it. A test that stashes state
     * somewhere fiber- or thread-pinned instead of in the scope fails here.
     *
     * Lifetime contract (deliberate, matching FiberLocal Layer 3): the
     * originating request extent is held OPEN — rendezvous on `done` —
     * until the continuation finishes, because a snapshot does NOT keep
     * the request bag alive past its extent; the bag and its beans drop
     * when this method returns, never earlier.
     */
    public static void requestAcrossHandoff(() -> void pre, () -> void continuation) {
        Channel<int32> ready = heap Channel<int32>(1);
        Channel<int32> done = heap Channel<int32>(1);
        // The producer side lives on a HandoffRun object: a captured function
        // param cannot be invoked from inside a nested lambda (bare-call
        // member resolution), but a function FIELD invoked from a method can
        // (the FilterStream `this.pred(v)` pattern).
        HandoffRun run = heap HandoffRun(pre, ready, done);
        scope {
            // Spawned BEFORE any request binding exists on this fiber, so
            // the worker inherits nothing — the snapshot is the only
            // carrier, exactly like a worker-pool fiber.
            spawn handoffWorker(ready, done, continuation);
            RequestScope.enter(() -> {
                run.insideScope();
            });
        }
    }

    static async void handoffWorker(Channel<int32> ready,
                                    Channel<int32> done,
                                    () -> void continuation) {
        ready.receive();
        PrimaveraTest.captured.run(continuation);
        done.send(1);
    }
}
