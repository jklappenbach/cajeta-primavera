package dev.cajeta.primavera.selftest;

import dev.cajeta.primavera.context.RequestScope;
import dev.cajeta.primavera.context.ScopeMap;
import dev.cajeta.primavera.context.SessionScope;
import dev.cajeta.primavera.context.SessionStore;

/**
 * primavera's runtime self-test — request scope (enter / store / lookup /
 * teardown / bean drop) and session scope (store lifecycle, idle + absolute
 * TTL expiry, eviction sweep, ambient access across requests). Self-contained
 * (no cajeta-unit dependency yet); the richer primavera test helpers built ON
 * cajeta-unit are a later increment (see plan/primavera-plan.md).
 *
 * Failures are accumulated through the static `check` helper rather than a
 * captured local, so closures passed to enter/attach mutate static state
 * directly (no mutable local capture).
 *
 * Session expiry is tested deterministically through SessionStore's `...At`
 * methods, which take the timestamp explicitly — no sleeping, no wall clock.
 *
 * Entry: `dev.cajeta.primavera.selftest.SelfTest.run` (returns 0 = all green).
 */
public class SelfTest {
    static int32 failures;

    static void check(boolean cond, String label) {
        if (cond == false) {
            System.stdout.println("  FAIL: " + label);
            SelfTest.failures = SelfTest.failures + 1;
        }
    }

    static void testRequestScope() {
        System.stdout.println("-- request scope --");
        String key = "dev.cajeta.primavera.selftest.Bean";
        Bean.drops = 0;

        // Outside any request, no scope is active and lookups are inert.
        SelfTest.check(RequestScope.isActive() == false, "no scope active before enter");
        SelfTest.check(RequestScope.has(key) == false, "has() false with no scope");
        SelfTest.check(RequestScope.lookup(key) == null, "lookup() null with no scope");

        RequestScope.enter(() -> {
            SelfTest.check(RequestScope.isActive(), "scope active inside enter");
            SelfTest.check(RequestScope.current().count() == 0, "fresh scope is empty");
            SelfTest.check(RequestScope.has(key) == false, "bean absent before store");

            Bean b = heap Bean(42);
            RequestScope.store(key, #b);

            SelfTest.check(RequestScope.has(key), "bean present after store");
            SelfTest.check(RequestScope.current().count() == 1, "scope holds one bean");

            Object got = RequestScope.lookup(key);
            SelfTest.check(got != null, "lookup returns the bean");
            Bean gb = (Bean) got;
            SelfTest.check(gb.value == 42, "looked-up bean carries its stored state");

            // Keys are matched by content, not identity: a distinct-but-equal
            // String object must find the same binding (reflective type names
            // are not guaranteed interned).
            String key2 = "dev.cajeta.primavera.selftest." + "Bean";
            SelfTest.check(RequestScope.has(key2), "lookup matches a distinct-but-equal key");

            SelfTest.check(Bean.drops == 0, "bean alive for the whole request extent");
        });

        // The bag — and the bean it owned — drop when enter() returns: the
        // bean's destructor must have run exactly once (leak-free scope end).
        SelfTest.check(RequestScope.isActive() == false, "no scope active after enter returns");
        SelfTest.check(Bean.drops == 1, "scope end drops the owned bean (destructor ran)");
    }

    static void testSessionStore() {
        System.stdout.println("-- session store (deterministic clock) --");
        String key = "dev.cajeta.primavera.selftest.Bean";

        // Idle TTL: resolves refresh the clock; going idle past the TTL
        // expires the session and drops its beans.
        Bean.drops = 0;
        if (true) {
            SessionStore store = heap SessionStore();
            store.setIdleTtl(1000);

            store.createAt("s1", 1000);
            SelfTest.check(store.count() == 1, "created session is held");

            ScopeMap bag = store.resolveAt("s1", 1500);
            SelfTest.check(bag != null, "resolve within idle TTL");
            Bean idleBean = heap Bean(7);
            bag.store(key, #idleBean);

            // 2400 is within 1000 of the last access (1500) — still live,
            // and the resolve refreshes lastAccessed to 2400.
            SelfTest.check(store.resolveAt("s1", 2400) != null, "idle clock refreshed by resolve");
            // 3500 is 1100 past the refreshed access — expired.
            SelfTest.check(store.resolveAt("s1", 3500) == null, "idle-expired session reads absent");
            SelfTest.check(Bean.drops == 1, "idle expiry drops the session's bean");
            SelfTest.check(store.count() == 0, "idle-expired session evicted on resolve");
        }

        // Absolute TTL: expires from createdAt regardless of activity.
        if (true) {
            SessionStore store = heap SessionStore();
            store.setAbsoluteTtl(1000);
            store.createAt("s1", 0);
            SelfTest.check(store.resolveAt("s1", 900) != null, "live within absolute TTL");
            SelfTest.check(store.resolveAt("s1", 1500) == null, "absolute TTL expires despite activity");
        }

        // Eviction sweep: expired sessions drop without being looked up.
        Bean.drops = 0;
        if (true) {
            SessionStore store = heap SessionStore();
            store.setIdleTtl(1000);
            store.createAt("s1", 0);
            store.createAt("s2", 0);
            store.createAt("s3", 5000);
            ScopeMap bag = store.resolveAt("s1", 0);
            Bean sweepBean = heap Bean(1);
            bag.store(key, #sweepBean);

            int32 evicted = store.evictExpiredAt(6000);
            SelfTest.check(evicted == 2, "sweep evicts exactly the expired sessions");
            SelfTest.check(store.count() == 1, "fresh session survives the sweep");
            SelfTest.check(Bean.drops == 1, "sweep drops evicted sessions' beans");
        }

        // Invalidate: immediate drop. Re-create under the same id displaces
        // (and drops) the old session.
        Bean.drops = 0;
        if (true) {
            SessionStore store = heap SessionStore();
            store.createAt("s1", 0);
            ScopeMap displacedBag = store.resolveAt("s1", 0);
            Bean displacedBean = heap Bean(1);
            displacedBag.store(key, #displacedBean);

            store.createAt("s1", 10);
            SelfTest.check(Bean.drops == 1, "re-create displaces and drops the old session");
            SelfTest.check(store.count() == 1, "displacement keeps one session");

            ScopeMap freshBag = store.resolveAt("s1", 10);
            Bean freshBean = heap Bean(2);
            freshBag.store(key, #freshBean);
            store.invalidate("s1");
            SelfTest.check(Bean.drops == 2, "invalidate drops the session's bean");
            SelfTest.check(store.resolveAt("s1", 10) == null, "invalidated session reads absent");
        }
    }

    static void testSessionScope() {
        System.stdout.println("-- session scope (ambient) --");
        String key = "dev.cajeta.primavera.selftest.Bean";
        Bean.drops = 0;

        // No id attached: inert accessors.
        SelfTest.check(SessionScope.isActive() == false, "no session active unattached");
        SelfTest.check(SessionScope.lookup(key) == null, "lookup null unattached");

        SessionScope.create("sess-A");

        // First "request": store a bean in the session.
        SessionScope.attach("sess-A", () -> {
            SelfTest.check(SessionScope.isActive(), "session active inside attach");
            SelfTest.check(SessionScope.has(key) == false, "session bag starts empty");
            Bean sessBean = heap Bean(11);
            SessionScope.store(key, #sessBean);
            SelfTest.check(SessionScope.has(key), "bean present after session store");
        });

        SelfTest.check(Bean.drops == 0, "attach end does NOT drop session beans");

        // Second "request", same session: the bean persisted.
        SessionScope.attach("sess-A", () -> {
            Object got = SessionScope.lookup(key);
            SelfTest.check(got != null, "bean persists across requests");
            Bean gb = (Bean) got;
            SelfTest.check(gb.value == 11, "persisted bean carries its state");
        });

        // A request attached to an unknown session id is sessionless.
        SessionScope.attach("sess-B", () -> {
            SelfTest.check(SessionScope.isActive() == false, "unknown id is not a live session");
            SelfTest.check(SessionScope.lookup(key) == null, "lookup null for unknown session");
        });

        // Isolation: a second session does not see the first one's beans.
        SessionScope.create("sess-C");
        SessionScope.attach("sess-C", () -> {
            SelfTest.check(SessionScope.has(key) == false, "sessions are isolated");
        });

        SessionScope.invalidate("sess-A");
        SelfTest.check(Bean.drops == 1, "invalidate drops the session's bean");
        SessionScope.invalidate("sess-C");
        SelfTest.check(SessionScope.sessionCount() == 0, "store empty after invalidations");
    }

    public static int32 run() {
        SelfTest.failures = 0;
        System.stdout.println("== primavera self-tests (request + session scope) ==");

        SelfTest.testRequestScope();
        SelfTest.testSessionStore();
        SelfTest.testSessionScope();

        if (SelfTest.failures == 0) {
            System.stdout.println("  all primavera self-tests passed");
            return 0;
        }
        System.stdout.println("  primavera self-tests FAILED");
        return 1;
    }
}
